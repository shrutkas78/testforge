<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="TestForge Regression Suite" parallel="methods" thread-count="3">
    <listeners>
        <listener class-name="com.testforge.tests.listeners.TestListener"/>
    </listeners>
    <test name="Full regression">
        <groups>
            <run>
                <include name="smoke"/>
                <include name="regression"/>
            </run>
        </groups>
        <packages>
            <package name="com.testforge.tests.ui.selenium"/>
        </packages>
    </test>
</suite>
